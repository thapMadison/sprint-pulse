// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`hero components (golden master DOM) > renderEpicHero (No Epic bucket) 1`] = `"<div class="sprint-hero epic-hero "><div class="card sprint-card epic-hero-card"><div class="sprint-card-header"><div class="name"><span class="issue-key-cell"><span class="epic-hero-key">NO EPIC</span></span><span class="epic-hero-name">No Epic</span></div><div class="epic-hero-badges"><span class="epic-hero-badge">Loose tasks</span></div></div><div class="sprint-meta"><div class="meta-item"><div class="meta-label">Start</div><div class="meta-value">24 Apr</div><div class="meta-sub">Fri</div></div><div class="meta-item"><div class="meta-label">End</div><div class="meta-value" style="color: var(--amber);">In progress</div><div class="meta-sub">no end yet</div></div><div class="meta-item"><div class="meta-label">Duration</div><div class="meta-value">28<span style="font-size: 13px; color: var(--ink-3); margin-left: 4px;">d</span></div><div class="meta-sub">days · ongoing</div></div><div class="meta-item"><div class="meta-label">Sprints</div><div class="meta-value">4</div><div class="meta-sub">spans 4 sprints</div></div></div></div><div class="stat-grid"><div class="card stat-tile"><div class="stat-label">Progress</div><div><div class="stat-value-row"><div class="stat-value">10<span class="unit">%</span></div><span class="stat-pct">4/17 issues</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--lime), var(--cyan)); transform: scaleX(0.1);"></span></div></div></div><div class="card stat-tile"><div class="stat-label">Total Effort</div><div><div class="stat-value-row"><div class="stat-value">139<span class="unit">h</span></div><span class="stat-pct">14h done</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--violet), var(--cyan)); transform: scaleX(0.10071942446043165);"></span></div></div></div><div class="card stat-tile"><div class="stat-label">In Progress</div><div><div class="stat-value-row"><div class="stat-value">0<span class="unit">tasks</span></div><span class="stat-pct">0h</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--amber), var(--coral)); transform: scaleX(0);"></span></div></div></div></div></div>"`;

exports[`hero components (golden master DOM) > renderEpicHero (real epic) 1`] = `"<div class="sprint-hero epic-hero loading"><div class="card sprint-card epic-hero-card"><div class="sprint-card-header"><div class="name"><span class="issue-key-cell"><span class="issue-type-icon type-epic" style="background: rgb(139, 92, 246); width: 18px; height: 18px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7z" fill="white" stroke="none"></path></svg></span><span class="epic-hero-key">EPIC-100</span></span><span class="epic-hero-name">Atlas Pipeline Foundations</span></div><div class="epic-hero-badges"><span class="epic-hero-badge loading">Loading...</span><span class="epic-hero-badge inprogress"><span class="pulse"></span>In Progress</span></div></div><p class="epic-hero-summary">Build the core import + metrics pipeline</p><div class="sprint-meta"><div class="meta-item"><div class="meta-label">Start</div><div class="meta-value">20 Apr</div><div class="meta-sub">Mon</div></div><div class="meta-item"><div class="meta-label">End</div><div class="meta-value" style="color: var(--amber);">In progress</div><div class="meta-sub">no end yet</div></div><div class="meta-item"><div class="meta-label">Duration</div><div class="meta-value">32<span style="font-size: 13px; color: var(--ink-3); margin-left: 4px;">d</span></div><div class="meta-sub">days · ongoing</div></div><div class="meta-item"><div class="meta-label">Sprints</div><div class="meta-value">2</div><div class="meta-sub">spans 2 sprints</div></div></div></div><div class="stat-grid"><div class="card stat-tile"><div class="stat-label">Progress</div><div><div class="stat-value-row"><div class="stat-value">53<span class="unit">%</span></div><span class="stat-pct">3/5 issues</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--lime), var(--cyan)); transform: scaleX(0.53);"></span></div></div></div><div class="card stat-tile"><div class="stat-label">Total Effort</div><div><div class="stat-value-row"><div class="stat-value">47<span class="unit">h</span></div><span class="stat-pct">25h done</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--violet), var(--cyan)); transform: scaleX(0.5319148936170213);"></span></div></div></div><div class="card stat-tile"><div class="stat-label">In Progress</div><div><div class="stat-value-row"><div class="stat-value">2<span class="unit">tasks</span></div><span class="stat-pct">22h</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--amber), var(--coral)); transform: scaleX(0.4);"></span></div></div></div></div></div>"`;

exports[`hero components (golden master DOM) > renderSprintHero 1`] = `"<div class="sprint-hero"><div class="card sprint-card"><div class="sprint-card-header"><div class="name">Sprint 24 — Atlas Release</div><div class="goal-info-wrap"><button class="goal-info-btn" type="button"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>Goal</button><div class="goal-popover"><div class="goal-popover-label">Sprint Goal</div><div class="goal-popover-text">Ship public beta of import pipeline + onboarding revamp</div></div></div></div><div class="sprint-meta"><div class="meta-item"><div class="meta-label">Start</div><div class="meta-value">11 May</div><div class="meta-sub">Mon</div></div><div class="meta-item"><div class="meta-label">End</div><div class="meta-value">29 May</div><div class="meta-sub">Fri</div></div><div class="meta-item"><div class="meta-label">Duration</div><div class="meta-value">15<span style="font-size: 13px; color: var(--ink-3); margin-left: 4px;">d</span></div><div class="meta-sub">working days</div></div><div class="meta-item"><div class="meta-label">Remaining</div><div class="meta-value" style="color: inherit;">6<span style="font-size: 13px; color: var(--ink-3); margin-left: 4px;">d</span></div><div class="meta-sub">working days</div></div></div></div><div class="stat-grid"><div class="card stat-tile"><div class="stat-label">Original Estimate</div><div><div class="stat-value">108<span class="unit">h</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--violet), var(--cyan));"></span></div></div></div><div class="card stat-tile"><div class="stat-label">Time Spent</div><div><div class="stat-value-row"><div class="stat-value">62<span class="unit">h</span></div><span class="stat-pct">57% of estimate</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--lime), var(--cyan)); animation: growBar 1.2s cubic-bezier(0.2,0.8,0.2,1) both; transform: scaleX(0.5694444444444444);"></span></div></div></div><div class="card stat-tile"><div class="stat-label">Remaining Effort</div><div><div class="stat-value">51<span class="unit">h</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--coral), var(--amber)); transform: scaleX(0.4722222222222222);"></span></div></div></div></div></div>"`;
