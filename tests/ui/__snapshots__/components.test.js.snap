exports[`UI components (golden master DOM) > renderTopbar (logged out) 1`] = `"<header class="topbar"><div class="brand"><div class="brand-mark"></div><div><h1>Sprint Pulse</h1><p>Jira Analytics · v0.4</p></div></div><div class="topbar-right"><div class="pill"><span class="dot"></span>Source · Demo · synced</div><div class="pill">Today 2026-05-22</div><div class="lang-menu"><button class="pill lang-pill" type="button" aria-label="Language"><span class="lang-globe">🌐</span><span class="lang-current">English</span><span class="user-chevron">▾</span></button><div class="lang-dropdown"><button class="lang-option " type="button" data-code="en">English</button><button class="lang-option " type="button" data-code="vi">Tiếng Việt</button></div></div><button class="pill auth-btn login"><span class="ms-icon"></span>Login with Microsoft</button></div></header>"`;

exports[`UI components (golden master DOM) > renderViewTabs 1`] = `"<div class="view-tabs"><button class="view-tab active" type="button" data-key="sprint"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><defs><linearGradient id="vtGradSprint" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop offset="0" style="stop-color: var(--violet);"></stop><stop offset="1" style="stop-color: var(--cyan);"></stop></linearGradient></defs><path d="M3 12h4l3-7 4 14 3-7h4"></path></svg>Sprint</button><button class="view-tab " type="button" data-key="epic"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><defs><linearGradient id="vtGradEpic" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse"><stop offset="0" style="stop-color: var(--violet);"></stop><stop offset="1" style="stop-color: var(--cyan);"></stop></linearGradient></defs><path d="M12 2 2 7l10 5 10-5-10-5Z"></path><path d="m2 17 10 5 10-5"></path><path d="m2 12 10 5 10-5"></path></svg>Epic</button></div>"`;

exports[`UI components (golden master DOM) > renderWorkloadTable 1`] = `"<div class="card"><h3 class="card-title"><span>User Workload Report</span><span class="card-subtitle">5 contributors · click a task for details</span></h3><div class="workload-search"><svg class="workload-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg><input class="workload-search-input" type="text" placeholder="Search tasks by key or summary…"></div><table class="workload-table"><thead><tr><th style="width: 240px;">Assignee</th><th>Status distribution</th><th style="text-align: right;">Estimate</th><th style="text-align: right;">Spent</th><th style="text-align: right;">Remaining</th><th style="width: 24px;"></th></tr></thead><tbody><tr class=""><td><div class="user-cell"><div class="avatar" style="background: rgb(34, 211, 238);">KT</div><div><div class="name">Khoa Tran</div><div class="sub">3 issues</div></div></div></td><td><div class="hbar-row"><div class="hbar"><span class="seg-done" style="width: 33.33333333333333%;"></span><span class="seg-inprog" style="width: 33.33333333333333%;"></span><span class="seg-todo" style="width: 33.33333333333333%;"></span></div><span class="num" style="font-size: 11px;"><span style="color: var(--lime);">1</span> / <span style="color: var(--amber);">1</span> / <span style="color: var(--ink-3);">1</span></span></div></td><td style="text-align: right; font-family: var(--font-mono);">29.0h</td><td style="text-align: right; font-family: var(--font-mono);">16.0h</td><td style="text-align: right; font-family: var(--font-mono); color: var(--coral);">14.0h</td><td><span class="expand-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"></polyline></svg></span></td></tr><tr class=""><td><div class="user-cell"><div class="avatar" style="background: rgb(167, 139, 250);">LN</div><div><div class="name">Linh Nguyen</div><div class="sub">3 issues</div></div></div></td><td><div class="hbar-row"><div class="hbar"><span class="seg-done" style="width: 33.33333333333333%;"></span><span class="seg-inprog" style="width: 66.66666666666666%;"></span><span class="seg-todo" style="width: 0%;"></span></div><span class="num" style="font-size: 11px;"><span style="color: var(--lime);">1</span> / <span style="color: var(--amber);">2</span> / <span style="color: var(--ink-3);">0</span></span></div></td><td style="text-align: right; font-family: var(--font-mono);">26.0h</td><td style="text-align: right; font-family: var(--font-mono);">18.5h</td><td style="text-align: right; font-family: var(--font-mono); color: var(--coral);">9.0h</td><td><span class="expand-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"></polyline></svg></span></td></tr><tr class=""><td><div class="user-cell"><div class="avatar" style="background: rgb(132, 204, 22);">DL</div><div><div class="name">Duc Le</div><div class="sub">3 issues</div></div></div></td><td><div class="hbar-row"><div class="hbar"><span class="seg-done" style="width: 66.66666666666666%;"></span><span class="seg-inprog" style="width: 33.33333333333333%;"></span><span class="seg-todo" style="width: 0%;"></span></div><span class="num" style="font-size: 11px;"><span style="color: var(--lime);">2</span> / <span style="color: var(--amber);">1</span> / <span style="color: var(--ink-3);">0</span></span></div></td><td style="text-align: right; font-family: var(--font-mono);">19.0h</td><td style="text-align: right; font-family: var(--font-mono);">12.5h</td><td style="text-align: right; font-family: var(--font-mono); color: var(--coral);">7.0h</td><td><span class="expand-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"></polyline></svg></span></td></tr><tr class=""><td><div class="user-cell"><div class="avatar" style="background: rgb(251, 113, 133);">MP</div><div><div class="name">Mai Pham</div><div class="sub">3 issues</div></div></div></td><td><div class="hbar-row"><div class="hbar"><span class="seg-done" style="width: 66.66666666666666%;"></span><span class="seg-inprog" style="width: 33.33333333333333%;"></span><span class="seg-todo" style="width: 0%;"></span></div><span class="num" style="font-size: 11px;"><span style="color: var(--lime);">2</span> / <span style="color: var(--amber);">1</span> / <span style="color: var(--ink-3);">0</span></span></div></td><td style="text-align: right; font-family: var(--font-mono);">18.0h</td><td style="text-align: right; font-family: var(--font-mono);">14.5h</td><td style="text-align: right; font-family: var(--font-mono); color: var(--coral);">5.0h</td><td><span class="expand-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"></polyline></svg></span></td></tr><tr class=""><td><div class="user-cell"><div class="avatar" style="background: rgb(245, 158, 11);">AV</div><div><div class="name">An Vu</div><div class="sub">3 issues</div></div></div></td><td><div class="hbar-row"><div class="hbar"><span class="seg-done" style="width: 0%;"></span><span class="seg-inprog" style="width: 0%;"></span><span class="seg-todo" style="width: 100%;"></span></div><span class="num" style="font-size: 11px;"><span style="color: var(--lime);">0</span> / <span style="color: var(--amber);">0</span> / <span style="color: var(--ink-3);">3</span></span></div></td><td style="text-align: right; font-family: var(--font-mono);">16.0h</td><td style="text-align: right; font-family: var(--font-mono);">0.0h</td><td style="text-align: right; font-family: var(--font-mono); color: var(--coral);">16.0h</td><td><span class="expand-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"></polyline></svg></span></td></tr></tbody></table></div>"`;
