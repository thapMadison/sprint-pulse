exports[`UI components (golden master DOM) > renderEpicDetailPanel 1`] = `"<div class="epic-detail-overlay"><div class="epic-detail-backdrop"></div><aside class="epic-detail-panel" role="dialog" aria-label="Details for Atlas Pipeline Foundations"><button class="epic-detail-close" type="button" aria-label="Close details">×</button><div class="epic-detail-body"><div class="sprint-hero epic-hero loading"><div class="card sprint-card epic-hero-card"><div class="sprint-card-header"><div class="name"><span class="issue-key-cell"><span class="issue-type-icon type-epic" style="background: rgb(139, 92, 246); width: 18px; height: 18px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7z" fill="white" stroke="none"></path></svg></span><span class="epic-hero-key">EPIC-100</span></span><span class="epic-hero-name">Atlas Pipeline Foundations</span></div><div class="epic-hero-badges"><span class="epic-hero-badge loading">Loading...</span><span class="epic-hero-badge inprogress"><span class="pulse"></span>In Progress</span></div></div><p class="epic-hero-summary">Build the core import + metrics pipeline</p><div class="sprint-meta"><div class="meta-item"><div class="meta-label">Start</div><div class="meta-value">20 Apr</div><div class="meta-sub">Mon</div></div><div class="meta-item"><div class="meta-label">End</div><div class="meta-value" style="color: var(--amber);">In progress</div><div class="meta-sub">no end yet</div></div><div class="meta-item"><div class="meta-label">Duration</div><div class="meta-value">32<span style="font-size: 13px; color: var(--ink-3); margin-left: 4px;">d</span></div><div class="meta-sub">days · ongoing</div></div><div class="meta-item"><div class="meta-label">Sprints</div><div class="meta-value">2</div><div class="meta-sub">spans 2 sprints</div></div></div></div><div class="stat-grid"><div class="card stat-tile"><div class="stat-label">Progress</div><div><div class="stat-value-row"><div class="stat-value">53<span class="unit">%</span></div><span class="stat-pct">3/5 issues</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--lime), var(--cyan)); transform: scaleX(0.53);"></span></div></div></div><div class="card stat-tile"><div class="stat-label">Total Effort</div><div><div class="stat-value-row"><div class="stat-value">47<span class="unit">h</span></div><span class="stat-pct">25h done</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--violet), var(--cyan)); transform: scaleX(0.5319148936170213);"></span></div></div></div><div class="card stat-tile"><div class="stat-label">In Progress</div><div><div class="stat-value-row"><div class="stat-value">2<span class="unit">tasks</span></div><span class="stat-pct">22h</span></div><div class="stat-bar"><span style="background: linear-gradient(90deg, var(--amber), var(--coral)); transform: scaleX(0.4);"></span></div></div></div></div><div class="card"><h3 class="card-title"><span>Status by Category</span><span class="accent"></span></h3><div class="donut-wrap"><svg width="200" height="200" viewBox="0 0 200 200"><defs><filter id="donutSoftGlow" x="-30%" y="-30%" width="160%" height="160%"><feGaussianBlur stdDeviation="4" result="blur"></feGaussianBlur><feComponentTransfer in="blur" result="softer"><feFuncA type="linear" slope="0.55"></feFuncA></feComponentTransfer><feMerge><feMergeNode in="softer"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge></filter></defs><circle cx="100" cy="100" r="89" fill="none" stroke="oklch(1 0 0 / 0.05)" stroke-width="22"></circle><g filter="url(#donutSoftGlow)"><path d="M 48.31743694172636 172.45628113371242 A 89 89 0 1 0 100 11" fill="none" stroke="var(--lime)" stroke-width="22" stroke-linecap="butt"></path><path d="M 99.22333834064476 11.003388847288747 A 89 89 0 0 0 47.6871125459699 172.0025124993703" fill="none" stroke="var(--amber)" stroke-width="22" stroke-linecap="butt"></path></g><text x="100" y="96" text-anchor="middle" class="donut-center-val" fill="var(--ink)" style="font: 500 28px var(--font-display)">5</text><text x="100" y="116" text-anchor="middle" fill="var(--ink-3)" style="font: 500 10px var(--font-mono); letter-spacing: 0.1em">ISSUES</text></svg><div class="donut-legend"><div class="donut-legend-row"><div class="left"><span class="sw" style="background: var(--lime);"></span><span>Done</span></div><div class="right"><span class="big">3</span><span style="color: var(--ink-3);"> · 25.0h</span></div></div><div class="donut-legend-row"><div class="left"><span class="sw" style="background: var(--amber);"></span><span>In Progress</span></div><div class="right"><span class="big">2</span><span style="color: var(--ink-3);"> · 22.0h</span></div></div><div class="donut-legend-row"><div class="left"><span class="sw" style="background: oklch(0.45 0.02 270);"></span><span>To Do</span></div><div class="right"><span class="big">0</span><span style="color: var(--ink-3);"> · 0.0h</span></div></div></div></div></div></div><div class="card"><h3 class="card-title"><span>Tasks in this Epic</span><span class="card-subtitle">5 tasks</span></h3><table class="workload-table epic-tasks-table"><thead><tr><th style="width: 90px;">Key</th><th>Summary</th><th style="width: 120px;">Sprint</th><th style="width: 180px;">Assignee</th><th style="width: 100px;">Status</th><th style="width: 70px;">Started</th><th style="width: 70px;">Done</th></tr></thead><tbody><tr><td><span class="issue-key-cell"><span class="issue-type-icon type-story" style="background: rgb(34, 197, 94); width: 16px; height: 16px;" title="Story"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h12v16l-6-4-6 4z"></path></svg></span><span class="mono-key">ATL-402</span></span></td><td class="epic-task-summary">Sprint metrics aggregation service</td><td><span class="sprint-chip">Sprint 24</span></td><td><div class="user-cell-mini"><div class="avatar-mini" style="background: rgb(34, 211, 238);">KT</div><span>Khoa Tran</span></div></td><td><span class="status-chip inprogress"><span class="sdot"></span>In Review</span></td><td class="mono-cell">14/05</td><td class="mono-cell">—</td></tr><tr><td><span class="issue-key-cell"><span class="issue-type-icon type-task" style="background: rgb(59, 130, 246); width: 16px; height: 16px;" title="Task"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17l9-10"></path></svg></span><span class="mono-key">ATL-411</span></span></td><td class="epic-task-summary">Status category mapping override</td><td><span class="sprint-chip">Sprint 24</span></td><td><div class="user-cell-mini"><div class="avatar-mini" style="background: rgb(167, 139, 250);">LN</div><span>Linh Nguyen</span></div></td><td><span class="status-chip inprogress"><span class="sdot"></span>In Progress</span></td><td class="mono-cell">19/05</td><td class="mono-cell">—</td></tr><tr><td><span class="issue-key-cell"><span class="issue-type-icon type-story" style="background: rgb(34, 197, 94); width: 16px; height: 16px;" title="Story"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h12v16l-6-4-6 4z"></path></svg></span><span class="mono-key">ATL-301</span></span></td><td class="epic-task-summary">Jira REST client wrapper</td><td><span class="sprint-chip">Sprint 23</span></td><td><div class="user-cell-mini"><div class="avatar-mini" style="background: rgb(34, 211, 238);">KT</div><span>Khoa Tran</span></div></td><td><span class="status-chip done"><span class="sdot"></span>Done</span></td><td class="mono-cell">20/04</td><td class="mono-cell">30/04</td></tr><tr><td><span class="issue-key-cell"><span class="issue-type-icon type-task" style="background: rgb(59, 130, 246); width: 16px; height: 16px;" title="Task"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17l9-10"></path></svg></span><span class="mono-key">ATL-302</span></span></td><td class="epic-task-summary">Issue + Sprint data schema</td><td><span class="sprint-chip">Sprint 23</span></td><td><div class="user-cell-mini"><div class="avatar-mini" style="background: rgb(167, 139, 250);">LN</div><span>Linh Nguyen</span></div></td><td><span class="status-chip done"><span class="sdot"></span>Done</span></td><td class="mono-cell">21/04</td><td class="mono-cell">27/04</td></tr><tr><td><span class="issue-key-cell"><span class="issue-type-icon type-bug" style="background: rgb(239, 68, 68); width: 16px; height: 16px;" title="Bug"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="7" width="8" height="11" rx="4"></rect><path d="M12 7V4M5 10h3M5 15h3M16 10h3M16 15h3"></path></svg></span><span class="mono-key">ATL-408</span></span></td><td class="epic-task-summary">API rate-limit retry with backoff</td><td><span class="sprint-chip">Sprint 24</span></td><td><div class="user-cell-mini"><div class="avatar-mini" style="background: rgb(34, 211, 238);">KT</div><span>Khoa Tran</span></div></td><td><span class="status-chip done"><span class="sdot"></span>Resolved</span></td><td class="mono-cell">13/05</td><td class="mono-cell">15/05</td></tr></tbody></table></div></div></aside></div>"`;

